# --- トレーディングエンジン設定（.env にコピーして使用） ---
# 既存の認証アプリ用
SECRET_KEY=change-me
DATABASE_URL=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# APIキーの保存時暗号化に使う鍵（未設定なら SECRET_KEY から導出）。
# 本番では十分にランダムな値を設定してください。web と worker で必ず同一に。
APP_ENCRYPTION_KEY=

# マルチテナント常駐ワーカーの実行間隔（秒）
WORKER_POLL_SECONDS=60

# --- OANDA v20 ---
# 既定は practice（デモ口座）。live にする場合は十分な検証後に。
OANDA_ENV=practice
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=

# --- 取引対象 ---
INSTRUMENTS=USD_JPY,EUR_USD
TRIGGER_GRANULARITY=M15
HTF_GRANULARITIES=H1,H4,D

# --- 指標パラメータ ---
ATR_PERIOD=14
ADX_PERIOD=14
EMA_FAST=20
EMA_MID=50
EMA_SLOW=200
ADX_TREND_THRESHOLD=25
ADX_RANGE_THRESHOLD=20

# --- エントリー条件 ---
BREAKOUT_LOOKBACK=20
ATR_MIN_PCT=0.30
VOLUME_LOOKBACK=20

# --- リスク管理 ---
RISK_PER_TRADE=0.5
ATR_STOP_MULT=1.5
ATR_TRAIL_MULT=2.0
MAX_OPEN_POSITIONS=2

# --- 安全装置（サーキットブレーカー / 0 で無効） ---
MAX_DAILY_LOSS=0
MAX_CONSECUTIVE_LOSSES=0
BREAKER_STATE_PATH=instance/breaker.json

# --- 取引永続化（ダッシュボード/統計, Phase 3） ---
TRADES_DB_PATH=instance/trading.db

# --- ニュース/中銀発言の解析（Phase 4, Claude API） ---
# ANTHROPIC_API_KEY か、`ant auth login` のプロファイルで認証
ANTHROPIC_API_KEY=

# --- Phase 5: ダマシ予測ML / 画像認識 / AI合議 ---
FAKEOUT_MIN_PROBA=0.5
FAKEOUT_MODEL_PATH=instance/fakeout_model.json
ML_MIN_SAMPLES=30

# --- 経済指標カレンダー（危険度フィルタ） ---
# ECON_CALENDAR_URL を設定すると engine で高重要度イベント前後を見送る
ECON_CALENDAR_URL=
ECON_CALENDAR_LIST_KEY=
# JSON のフィールド名が既定（date/country/impact/title）と異なる場合に上書き
ECON_CALENDAR_FIELD_TIME=
ECON_CALENDAR_FIELD_CURRENCY=
ECON_CALENDAR_FIELD_IMPORTANCE=
ECON_CALENDAR_FIELD_TITLE=
ECON_BLACKOUT_BEFORE_MIN=30
ECON_BLACKOUT_AFTER_MIN=15
ECON_IMPORTANCE_MIN=high
